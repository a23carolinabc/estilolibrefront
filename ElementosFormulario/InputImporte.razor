@inherits InputNumerico
@using Utils;

@RenderBase()

@code {

    private RenderFragment RenderBase() => builder => base.BuildRenderTree(builder);

    protected override string FormatearNumero(decimal decNumero, int iNumDecimales)
    {
        //Si el número es cero y se ha indicado en la configuración que el cero se formatea como la
        //cadena vacía.
        if (this.FormatearCeroComoCadenaVacia && (decNumero == 0.0M))
        {
            return "";
        }

        return UtilsFormat.FormatearImporte(decNumero, this.NumeroDeDecimales);
    }

    protected override bool EsNumeroValido(string strTexto, bool bCeroComoCadenaVacia)
    {
        //En caso de permitir cadenas vacias.
        if (strTexto == "" && bCeroComoCadenaVacia)
        {
            return true;
        }

        //Parsear el texto.
        return UtilsConversion.EsNumeroDecimal(strTexto);
    }

    protected override decimal GetNumero(string strTexto, bool bCeroComoCadenaVacia)
    {
        decimal decNumero;

        //En caso de permitir cadenas vacías.
        if (strTexto == "" && bCeroComoCadenaVacia)
        {
            return 0;
        }

        decNumero = UtilsConversion.GetImporteMoneda(strTexto);
        return decNumero;
    }
}
