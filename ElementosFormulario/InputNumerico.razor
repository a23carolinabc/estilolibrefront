@inherits InputBase<decimal?>
@using System.Linq.Expressions
@using Utils;

<input type="text" @bind-value:event="oninput" @bind-value=@this._strValorInputActualizado @attributes=@AtributosInput
@onkeyup=@this.OnKeyUp @onchange=this.OnInput maxlength="16" class=@this.ClaseCss />

@code {

    #region ***** VARIABLES INTERNAS *****

    public required InputText _inputTextRef;
    public string? _strValorInputActualizado;

    #endregion

    #region ***** PARÁMETROS *****

    [Parameter]
    public string ClaseCss { get; set; } = "";

    [Parameter]
    public Dictionary<string, object>? AtributosInput { get; set; }

    [Parameter]
    public bool ConsiderarCadenaVaciaComoCero { get; set; } = true;

    [Parameter]
    public int NumeroDeDecimales { get; set; } = 2;

    [Parameter]
    public bool FormatearCeroComoCadenaVacia { get; set; } = false;

    [Parameter]
    public string MensajeErrorValidacion { get; set; } = "";

    #endregion

    #region ***** MÉTODOS PÚBLICOS *****

    protected override void OnInitialized()
    {
    }

    protected override void OnParametersSet()
    {
        this._strValorInputActualizado = this.FormatValueAsString(this.Value);
    }

    protected override bool TryParseValueFromString(string? strValor, out decimal? result, out string validationErrorMessage)
    {
        if (!this.ParsearTexto(this._strValorInputActualizado, out result, out _))
        {
            validationErrorMessage = this.MensajeErrorValidacion;
            return false;
        }

        validationErrorMessage = "";
        return true;
    }

    protected override string FormatValueAsString(decimal? decNumero)
    {
        return this.FormatearNumero(decNumero ?? 0M, this.NumeroDeDecimales);
    }

    protected virtual string FormatearNumero(decimal decNumero, int iNumDecimales)
    {
        //Si el número es cero y se ha indicado en la configuración que el cero se formatea como la
        //cadena vacía.
        if (this.FormatearCeroComoCadenaVacia && (decNumero == 0.0M))
        {
            return "";
        }

        return UtilsFormat.FormatearNumero(decNumero, this.NumeroDeDecimales);
    }

    protected virtual bool EsNumeroValido(string strTexto, bool bCeroComoCadenaVacia)
    {
        //En caso de permitir cadenas vacias.
        if (strTexto == "" && bCeroComoCadenaVacia)
        {
            return true;
        }

        //Parsear el texto.
        return UtilsConversion.EsNumeroDecimal(strTexto);
    }

    protected virtual decimal GetNumero(string strTexto, bool bCeroComoCadenaVacia)
    {
        decimal decNumero;

        //En caso de permitir cadenas vacías.
        if (strTexto == "" && bCeroComoCadenaVacia)
        {
            return 0;
        }

        decNumero = UtilsConversion.GetNumeroDecimal(strTexto);
        return decNumero;
    }

    public async Task HandleValueChange(ChangeEventArgs e)
    {

    }

    #endregion

    #region ***** MÉTODOS PRIVADOS *****

    private void OnKeyUp(KeyboardEventArgs e)
    {
        string strTexto;
        char strSeparadorDecimales;
        int iUltimoIndicePunto;

        strTexto = this._strValorInputActualizado ?? "";
        strSeparadorDecimales = ',';

        //Si la longitud del texto es demasiado corta, no se hace nada.
        if (strTexto.Length < 2) return;

        //Si han pulsado la tecla de punto del teclado numérico.
        if (e.Code == "NumpadDecimal")
        {
            //Si ya existe el separador de decimales, no se puede hacer nada.
            if (strTexto.IndexOf(strSeparadorDecimales) > 0) return;

            //Si el punto es único y éste está al final del texto, se sustituye.
            iUltimoIndicePunto = strTexto.LastIndexOf('.');
            if (iUltimoIndicePunto == strTexto.Length - 1)
            {
                if (strTexto.IndexOf('.') == iUltimoIndicePunto)
                {
                    //El punto lo acaban de insertar al final. Sustituir.
                    this._strValorInputActualizado = strTexto.Replace('.', strSeparadorDecimales);
                    return;
                }

                //Hay más de un punto, pero el nuevo lo han puesto al final.
                if ((strTexto == strTexto.Substring(0, strTexto.Length - 1)) &&
                    (strTexto[strTexto.Length - 1] == '.') &&
                    (strTexto[strTexto.Length - 2] != '.'))
                {
                    this._strValorInputActualizado = strTexto + strSeparadorDecimales;
                    return;
                }
            }
        }
    }

    private void OnInput(ChangeEventArgs e)
    {
        decimal? decResultado;
        string? strResultadoFormateado;

        if (this.ParsearTexto(this._strValorInputActualizado, out decResultado, out strResultadoFormateado))
        {
            this._strValorInputActualizado = strResultadoFormateado;
        }

        //Esta asignación provocará el lanzamiento del TryParseValueFromString.
        this.CurrentValueAsString = strResultadoFormateado;
    }

    private bool ParsearTexto(string? strValor, out decimal? decResultado, out string? strNumeroReformateado)
    {
        string strTextoEnInput;
        decimal decNumero;
        string strNumeroFormateado;

        strNumeroReformateado = strValor;
        strTextoEnInput = strValor ?? "";
        if (strTextoEnInput == "" && !this.ConsiderarCadenaVaciaComoCero)
        {
            decResultado = null;
            return true;
        }
        else if (strTextoEnInput == "" && this.ConsiderarCadenaVaciaComoCero)
        {
            decResultado = 0;
            return true;
        }
        else if (!this.EsNumeroValido(strTextoEnInput, this.ConsiderarCadenaVaciaComoCero))
        {
            decResultado = null;
            return false;
        }
        else
        {
            decNumero = this.GetNumero(strTextoEnInput, this.ConsiderarCadenaVaciaComoCero);
            strNumeroFormateado = this.FormatearNumero(decNumero, this.NumeroDeDecimales);
            //NOTA: Volvemos a parsear porque a lo mejor el formateador aplicó un redondeo. Por ejemplo, si
            //el usuario introduce un número con muchos decimales y sólo debería mostrarse 1.
            decNumero = this.GetNumero(strNumeroFormateado, this.ConsiderarCadenaVaciaComoCero);

            strNumeroReformateado = strNumeroFormateado;
            decResultado = decNumero;
            return true;
        }
    }

    #endregion
}
