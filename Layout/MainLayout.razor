@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider />
<MudPopoverProvider />
@* Needed for dialogs *@
<MudDialogProvider />
@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer Open="true" Elevation="0" Variant="@DrawerVariant.Persistent"
               Class="mud-theme-success" ClipMode="DrawerClipMode.Never">
        <MenuLateral />
    </MudDrawer>
    
    <!-- Contenido principal sin padding adicional -->
    <MudMainContent Class="main-content-custom">
        <MudAppBar Elevation="1" Dense="false" Class="appbar-principal">
            <MenuSuperior />
        </MudAppBar>

        <div class="page-content-container">
            <CascadingValue Value="this">
                @Body
            </CascadingValue>
        </div>
    </MudMainContent>
</MudLayout>

@code {
    #region ***** DEPENDENCIAS *****
    #endregion

    #region ***** PARÁMETROS *****
    #endregion

    #region ***** PROPIEDADES PÚBLICAS *****

    public string TituloCabecera { get; private set; } = string.Empty;

    #endregion

    #region ***** MÉTODOS PÚBLICOS *****

    /// <summary>
    /// Actualiza el título de la cabecera y refresca la interfaz.
    /// </summary>
    /// <param name="strTitulo">Nuevo título a mostrar</param>
    public void CambiarTituloCabecera(string strTitulo)
    {
        this.TituloCabecera = strTitulo ?? string.Empty;
        this.StateHasChanged();
    }

    #endregion

    #region ***** MÉTODOS PRIVADOS *****
    #endregion
}