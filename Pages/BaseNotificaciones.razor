@using Blazored.SessionStorage

<MensajeInfo></MensajeInfo>
<ElementoCarga @ref=ElementoCarga EspacioParaTexto=@EspacioParaTexto></ElementoCarga>
<PopUpConfirmacion @ref=PopUpConfirmacion EnvioRespuesta=EnvioRespuestaPopUp></PopUpConfirmacion>

@code {
    #region ***** DEPENDENCIAS *****

    [Inject]
    public ServicioMensajeInfo MensajeInformativo { get; set; }    

    #endregion

    #region ***** PARÁMETROS *****

    [Parameter]
    public ElementoCarga ElementoCarga { get; set; }

    [Parameter]
    public PopUpConfirmacion PopUpConfirmacion { get; set; }

    [Parameter]
    public string EspacioParaTexto { get; set; } = "";

    [Parameter, EditorRequired]
    public EventCallback<bool> EnvioRespuesta { get; set; }

    #endregion

    #region ***** MÉTODOS PÚBLICOS *****    

    public void OcultarElementoCarga()
    {
        this.ElementoCarga.VisibilidadElementoCarga(false);
    }
    public void MostrarElementoCarga()
    {
        this.ElementoCarga.VisibilidadElementoCarga(true);
    }

    public void SetMensajeInformativo(string mensaje, int iDuracion=3000)
    {
        this.MensajeInformativo.TextoMensaje(mensaje, iDuracion);
    }
    public void SetMensajePopUp(string mensaje, string titulo, bool botonesSN = true)
    {
        this.PopUpConfirmacion.TextoPopUp(mensaje, titulo, botonesSN);

    }
    public async void EnvioRespuestaPopUp(bool valor)
    {
        await this.EnvioRespuesta.InvokeAsync(valor);
    }
    #endregion
}
