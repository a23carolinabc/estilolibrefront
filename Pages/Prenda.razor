@page "/prendas/crear"
@layout MainLayout
@using EstiloLibreFront.Objetos.Prendas
@using EstiloLibreFront.Servicios
@inject ServicioPrendas ServicioPrendas
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Crear Nueva Prenda</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" Class="mr-2" />
        Crear Nueva Prenda
    </MudText>

    @if (this._cargandoDatos)
    {
        <!-- Pantalla de carga inicial -->
        <MudPaper Class="pa-4 text-center">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-2">Cargando formulario...</MudText>
        </MudPaper>
    }
    else if (this._prendaData == null)
    {
        <!-- Error al cargar datos -->
        <MudAlert Severity="Severity.Error">
            Error al cargar los datos del formulario. Por favor, intenta recargar la página.
        </MudAlert>
    }
    else
    {
        <EditForm Model="@(this._prendaData?.Prenda ?? new PrendaDTO())" OnValidSubmit="this.GuardarPrenda">
            <DataAnnotationsValidator />

            <!-- ============================================ -->
            <!-- SECCIÓN 1: IMAGEN DE LA PRENDA             -->
            <!-- ============================================ -->
            <MudCard Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Image" Class="mr-2" />
                            Foto de la Prenda
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>

                    <InputFile id="fileInput"
                               OnChange="this.CargarImagen"
                               accept="image/*"
                               class="d-none" />

                    @if (this._procesandoImagen)
                    {
                        <!-- Mostrar mientras se elimina el fondo -->
                        <div class="text-center pa-4">
                            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.body1" Class="mt-2">
                                Eliminando fondo de la imagen con IA...
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Esto puede tardar unos segundos la primera vez
                            </MudText>
                        </div>
                    }
                    else
                    {
                        <!-- Botón para seleccionar imagen -->
                        <InputFile id="fileInput"
                                   OnChange="this.CargarImagen"
                                   accept="image/*"
                                   class="d-none" />

                        <MudButton HtmlTag="label"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   for="fileInput"
                                   FullWidth="true">
                            @(string.IsNullOrEmpty(this._imagenPreview) ? "Seleccionar Imagen" : "Cambiar Imagen")
                        </MudButton>

                        <!-- Preview de la imagen -->
                        @if (!string.IsNullOrEmpty(this._imagenPreview))
                        {
                            <MudPaper Class="mt-4 pa-2 text-center" Style="background-color: #f5f5f5;">
                                <MudImage Src="@this._imagenPreview"
                                          Alt="Vista previa"
                                          Style="max-width: 100%; max-height: 400px; border: 2px solid #ddd; border-radius: 8px;" />
                                <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Success">
                                    ✓ Fondo eliminado correctamente
                                </MudText>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Class="mt-2">
                                Selecciona una imagen de tu prenda. El fondo se eliminará automáticamente.
                            </MudAlert>
                        }
                    }

                </MudCardContent>
            </MudCard>

            <!-- ============================================ -->
            <!-- SECCIÓN 2: INFORMACIÓN BÁSICA              -->
            <!-- ============================================ -->
            <MudCard Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                            Información Básica
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>

                    <!-- Color -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.ColorId"
                               Label="Color *"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Required="true">
                        <MudSelectItem Value="0">Seleccione un color</MudSelectItem>
                        @if (this._prendaData.Colores != null)
                        {
                            @foreach (var color in this._prendaData.Colores)
                            {
                                <MudSelectItem Value="@color.Id">@color.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Categoría -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.CategoriaId"
                               Label="Categoría *"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Required="true">
                        <MudSelectItem Value="0">Seleccione una categoría</MudSelectItem>
                        @if (this._prendaData.Categorias != null)
                        {
                            @foreach (var categoria in this._prendaData.Categorias)
                            {
                                <MudSelectItem Value="@categoria.Id">@categoria.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Talla -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.TallaId"
                               Label="Talla *"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Required="true">
                        <MudSelectItem Value="0">Seleccione una talla</MudSelectItem>
                        @if (this._prendaData.Tallas != null)
                        {
                            @foreach (var talla in this._prendaData.Tallas)
                            {
                                <MudSelectItem Value="@talla.Id">@talla.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Estado -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.EstadoId"
                               Label="Estado *"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Required="true">
                        <MudSelectItem Value="0">Seleccione un estado</MudSelectItem>
                        @if (this._prendaData.Estados != null)
                        {
                            @foreach (var estado in this._prendaData.Estados)
                            {
                                <MudSelectItem Value="@estado.Id">@estado.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Material -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.MaterialId"
                               Label="Material *"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Required="true">
                        <MudSelectItem Value="0">Seleccione un material</MudSelectItem>
                        @if (this._prendaData.Materiales != null)
                        {
                            @foreach (var material in this._prendaData.Materiales)
                            {
                                <MudSelectItem Value="@material.Id">@material.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                </MudCardContent>
            </MudCard>

            <!-- ============================================ -->
            <!-- SECCIÓN 3: INFORMACIÓN ADICIONAL (OPCIONAL) -->
            <!-- ============================================ -->
            <MudCard Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Class="mr-2" />
                            Información Adicional (Opcional)
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>

                    <!-- Marca -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.MarcaId"
                               Label="Marca (Opcional)"
                               Variant="Variant.Outlined"
                               Class="mb-3">
                        <MudSelectItem Value="0">Sin marca</MudSelectItem>
                        @if (this._prendaData.Marcas != null)
                        {
                            @foreach (var marca in this._prendaData.Marcas)
                            {
                                <MudSelectItem Value="@marca.Id">@marca.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Estación -->
                    <MudSelect @bind-Value="this._prendaData.Prenda.EstacionId"
                               Label="Estación (Opcional)"
                               Variant="Variant.Outlined"
                               Class="mb-3">
                        <MudSelectItem Value="0">Todas las estaciones</MudSelectItem>
                        @if (this._prendaData.Estaciones != null)
                        {
                            @foreach (var estacion in this._prendaData.Estaciones)
                            {
                                <MudSelectItem Value="@estacion.Id">@estacion.Nombre</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <!-- Precio -->
                    <MudNumericField @bind-Value="this._prendaData.Prenda.Precio"
                                     Label="Precio (€)"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Class="mb-3" />

                    <!-- Enlace de Compra -->
                    <MudTextField @bind-Value="this._prendaData.Prenda.EnlaceCompra"
                                  Label="Enlace de Compra (URL)"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />

                    <!-- Fecha de Compra -->
                    <MudDatePicker @bind-Date="this._fechaCompra"
                                   Label="Fecha de Compra"
                                   Variant="Variant.Outlined" />

                </MudCardContent>
            </MudCard>

            <!-- ============================================ -->
            <!-- BOTONES DE ACCIÓN                          -->
            <!-- ============================================ -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => this.NavigationManager.NavigateTo("/"))">
                    Cancelar
                </MudButton>

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="@(this._guardando || string.IsNullOrEmpty(this._imagenPreview))">
                    @(this._guardando ? "Guardando..." : "Guardar Prenda")
                </MudButton>
            </MudStack>

        </EditForm>
    }
</MudContainer>

@code {
    // ============================================
    // PROPIEDADES PRIVADAS
    // ============================================
    private PrendaData? _prendaData = null;
    private string _imagenPreview = string.Empty;
    private DateTime? _fechaCompra;
    private bool _cargandoDatos = true;
    private bool _procesandoImagen = false;
    private bool _guardando = false;

    // ============================================
    // INICIALIZACIÓN DEL COMPONENTE
    // ============================================
    protected override async Task OnInitializedAsync()
    {
        try
        {
            this._cargandoDatos = true;

            // Cargar datos necesarios para el formulario
            this._prendaData = await this.ServicioPrendas.AddNew();

            // Verificar que se cargaron los datos
            if (this._prendaData == null)
            {
                this.Snackbar.Add("Error: No se pudieron cargar los datos del formulario", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            this.Snackbar.Add($"Error al cargar datos: {ex.Message}", Severity.Error);
            Console.WriteLine($"Error completo: {ex}");
            this._prendaData = null;
        }
        finally
        {
            this._cargandoDatos = false;
        }
    }

    // ============================================
    // MÉTODO: CARGAR Y PROCESAR IMAGEN
    // ============================================
    private async Task CargarImagen(InputFileChangeEventArgs e)
    {
        try
        {
            // Activar indicador de procesamiento
            this._procesandoImagen = true;
            StateHasChanged();

            var archivo = e.File;

            // Validar tamaño (máximo 10MB)
            if (archivo.Size > 10 * 1024 * 1024)
            {
                this.Snackbar.Add("La imagen es demasiado grande. Máximo 10MB.", Severity.Warning);
                this._procesandoImagen = false;
                StateHasChanged();
                return;
            }

            this.Snackbar.Add("Procesando imagen...", Severity.Info);

            // 1. Leer imagen completamente antes de liberar el stream
            byte[] imageBytes;
            using (var stream = archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                imageBytes = ms.ToArray();
            }

            // Convertir a base64 inmediatamente para liberar recursos
            var imagenOriginalBase64 = $"data:{archivo.ContentType};base64,{Convert.ToBase64String(imageBytes)}";

            Console.WriteLine("Imagen cargada, iniciando eliminación de fondo...");

            // 2. LLAMAR A JAVASCRIPT PARA ELIMINAR FONDO
            // Usar InvokeAsync con timeout para evitar bloqueos
            var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(60)); // 60 segundos timeout

            string imagenSinFondoBase64;
            try
            {
                imagenSinFondoBase64 = await this.JSRuntime.InvokeAsync<string>(
                    "removeImageBackground",
                    cancellationTokenSource.Token,
                    imagenOriginalBase64
                );
            }
            catch (TaskCanceledException)
            {
                this.Snackbar.Add("Tiempo de espera agotado al procesar la imagen", Severity.Error);
                this._procesandoImagen = false;
                StateHasChanged();
                return;
            }

            Console.WriteLine("Fondo eliminado correctamente");

            // 3. GUARDAR RESULTADO
            if (!string.IsNullOrEmpty(imagenSinFondoBase64))
            {
                // Para preview
                this._imagenPreview = imagenSinFondoBase64;

                // Para enviar al servidor
                if (imagenSinFondoBase64.Contains(","))
                {
                    this._prendaData.Prenda.FotoBase64 = imagenSinFondoBase64.Split(',')[1];
                }
                else
                {
                    this._prendaData.Prenda.FotoBase64 = imagenSinFondoBase64;
                }

                this.Snackbar.Add("✓ Fondo eliminado correctamente", Severity.Success);
            }
            else
            {
                throw new Exception("No se recibió resultado del procesamiento");
            }
        }
        catch (Exception ex)
        {
            this.Snackbar.Add($"Error al procesar imagen: {ex.Message}", Severity.Error);
            Console.WriteLine($"Error detallado: {ex}");

            // Limpiar preview si hay error
            this._imagenPreview = string.Empty;
            if (this._prendaData?.Prenda != null)
            {
                this._prendaData.Prenda.FotoBase64 = string.Empty;
            }
        }
        finally
        {
            this._procesandoImagen = false;
            StateHasChanged();
        }
    }

    // ============================================
    // MÉTODO: GUARDAR PRENDA
    // ============================================
    private async Task GuardarPrenda()
    {
        int prendaId;

        try
        {
            this._guardando = true;

            // Validar que hay imagen
            if (string.IsNullOrEmpty(this._prendaData.Prenda.FotoBase64))
            {
                this.Snackbar.Add("Debe seleccionar una imagen", Severity.Warning);
                return;
            }

            // Validar campos obligatorios
            if (this._prendaData.Prenda.ColorId == 0 ||
                this._prendaData.Prenda.CategoriaId == 0 ||
                this._prendaData.Prenda.EstadoId == 0 ||
                this._prendaData.Prenda.TallaId == 0 ||
                this._prendaData.Prenda.MaterialId == 0)
            {
                this.Snackbar.Add("Complete todos los campos obligatorios (*)", Severity.Warning);
                return;
            }

            // Convertir fecha si existe
            if (this._fechaCompra.HasValue)
            {
                this._prendaData.Prenda.FechaCompra = this._fechaCompra.Value;
            }

            this.Snackbar.Add("Guardando prenda...", Severity.Info);

            // Enviar al servidor
            prendaId = await this.ServicioPrendas.SaveData(this._prendaData.Prenda);

            this.Snackbar.Add($"✓ Prenda guardada correctamente (ID: {prendaId})", Severity.Success);

            // Esperar un momento para que el usuario vea el mensaje
            await Task.Delay(1500);

            // Navegar a inicio
            this.NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            this.Snackbar.Add($"Error al guardar: {ex.Message}", Severity.Error);
            Console.WriteLine($"Error detallado: {ex}");
        }
        finally
        {
            this._guardando = false;
        }
    }
}